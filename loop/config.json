{
  "version": 1,
  "phases": [
    "discover",
    "decide",
    "design",
    "build",
    "verify",
    "learn",
    "release"
  ],
  "gates": {
    "discover": ["problem_statement", "market_evidence", "pricing_evidence"],
    "decide": ["selected_direction", "success_metric", "kill_criteria"],
    "design": ["architecture", "vertical_slice", "verification_plan"],
    "build": ["build_result"],
    "verify": ["test_result", "runtime_proof", "checker_result"],
    "learn": ["learning", "next_hypothesis"],
    "release": ["release_result"]
  },
  "scoring": {
    "pain": {"weight": 1.4, "direction": "higher"},
    "frequency": {"weight": 1.2, "direction": "higher"},
    "demand": {"weight": 1.4, "direction": "higher"},
    "aiLeverage": {"weight": 1.0, "direction": "higher"},
    "nativeLeverage": {"weight": 1.0, "direction": "higher"},
    "buildSpeed": {"weight": 1.2, "direction": "higher"},
    "opsEfficiency": {"weight": 1.0, "direction": "higher"},
    "monetization": {"weight": 0.8, "direction": "higher"},
    "defensibility": {"weight": 0.6, "direction": "higher"},
    "risk": {"weight": 1.2, "direction": "lower"}
  },
  "git": {
    "branchPattern": "agent/{issue}-{slug}",
    "worktreeRoot": "../.worktrees/{repo}",
    "commitPattern": "loop({product}): {message}"
  }
}
